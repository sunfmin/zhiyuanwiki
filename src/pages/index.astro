---
// 根路径跳转到默认省份（黑龙江）。对称 /[prov]/ 路由下，/ 只做落地跳转。见 ADR-0009。
import { DEFAULT_PROVINCE } from "../lib/provinces";
const target = `/${DEFAULT_PROVINCE}/`;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>高考志愿数据 Wiki</title>
  </head>
  <body>
    <p>正在前往 <a href={target}>高考志愿数据 Wiki</a>…</p>
  </body>
</html>
