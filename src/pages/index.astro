---
// 省份列表落地页（替换旧的「跳转默认省」根路由，见 ADR-0016）。
// 纯静态：列全 31 省，已上线置顶可点进 /[slug]/，未上线置灰「敬请期待」。
// 列分两轴——省情（新高考·本省院校·高考人数·本科线·本科招生计划）/ 本站收录（招生院校·覆盖年份·名校）。
import Base from "../layouts/Base.astro";
import { PROVINCE_ROSTER, liveSlugByName, provinceConfig, fillRange } from "../lib/provinces";
import { buildProvinceRows, summarize, coverageYears, type Gaokao } from "../lib/landing";
import { schoolsOf, homeSchoolsOf, gaokaoOf, benkeLineOf, benkePlanOf } from "../lib/data";

const live = liveSlugByName();
const rows = buildProvinceRows(
  PROVINCE_ROSTER,
  live,
  (slug) => summarize(schoolsOf(slug)),
  (name) => homeSchoolsOf(name),
  (slug) => gaokaoOf(slug),
  (slug) => benkeLineOf(slug),
  (slug) => benkePlanOf(slug),
);

// 高考模式（省情轴，配置派生）：老高考 理科/文科（新疆）、3+3 综合 或 3+1+2 物理/历史。
function modeLabel(slug: string): string {
  const c = provinceConfig(slug);
  const mode =
    c.subjectMode === "wenli"
      ? "老高考"
      : c.subjectMode === "pick3of7" || c.subjectMode === "pick3of6"
        ? "3+3"
        : "3+1+2";
  return `${mode} · ${c.tracks.map((t) => t.name).join("/")}`;
}
// 志愿填报（省情，时间敏感）：紧凑串进表格一格，完整起止+截止时刻+段次备注进 title 悬浮。
const fillOf = (slug: string) => provinceConfig(slug).fill;
const fillCell = (slug: string): string => {
  const f = fillOf(slug);
  return f ? fillRange(f) : "—";
};
const fillTitle = (slug: string): string | undefined => {
  const f = fillOf(slug);
  if (!f) return undefined;
  return `2026 本科批志愿填报 ${fillRange(f)}${f.endTime ? ` ${f.endTime} 截止` : ""}${f.note ? `（${f.note}）` : ""}`;
};
const fmt = (n: number) => n.toLocaleString("zh-CN");
// 大数显示成「万」（含一位小数）；title 给精确数与年份。高考人数、本科招生计划共用。
const wanNum = (n: number) => `${(n / 10000).toFixed(1)}万`;
const wan = (g: Gaokao) => wanNum(g.count);
const liveCount = rows.filter((r) => r.live).length;
---

<Base
  title="全国高考志愿数据 Wiki · 选择省份"
  description={`覆盖 ${liveCount} 省的历年官方录取数据：按等效位次给出冲 / 稳 / 保。选择你的省份开始。`}
>
  <section class="mx-auto max-w-5xl px-4 py-8 sm:py-12">
    <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">选择你的省份</h1>
    <p class="mt-2 max-w-2xl text-sm text-slate-600 sm:text-base">
      用历年官方数据按<strong>等效位次</strong>给出冲 / 稳 / 保的可填报院校与专业。
      已上线 {liveCount} 省，点击进入位次定位；其余省份陆续接入。
    </p>

    {/* 桌面：分组宽表（省情 / 本站收录两轴） */}
    <div class="mt-6 hidden overflow-x-auto md:block">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="text-xs text-slate-400">
            <th class="px-3 py-1.5 text-left font-medium" rowspan="2">省份</th>
            <th class="border-l border-slate-200 px-3 py-1.5 text-center font-medium" colspan="6">省情</th>
            <th class="border-l border-slate-200 px-3 py-1.5 text-center font-medium" colspan="4">
              本站收录
            </th>
          </tr>
          <tr class="text-xs text-slate-500">
            <th class="border-l border-slate-200 px-3 py-1.5 text-left font-medium">志愿填报<sup class="text-slate-300">§</sup></th>
            <th class="px-3 py-1.5 text-left font-medium">高考模式</th>
            <th class="px-3 py-1.5 text-right font-medium">本省院校</th>
            <th class="px-3 py-1.5 text-right font-medium">高考人数<sup class="text-slate-300">*</sup></th>
            <th class="px-3 py-1.5 text-right font-medium">本科线<sup class="text-slate-300">†</sup></th>
            <th class="px-3 py-1.5 text-right font-medium">本科招生计划<sup class="text-slate-300">‡</sup></th>
            <th class="border-l border-slate-200 px-3 py-1.5 text-right font-medium">招生院校</th>
            <th class="px-3 py-1.5 text-right font-medium">覆盖年份</th>
            <th class="px-3 py-1.5 text-right font-medium">985</th>
            <th class="px-3 py-1.5 text-right font-medium">211</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((r) =>
              r.live && r.slug ? (
                <tr class="border-t border-slate-100 hover:bg-slate-50">
                  <td class="px-3 py-2 font-medium">
                    <a href={`/${r.slug}/`} class="text-slate-900 hover:text-blue-700 hover:underline">
                      {r.name}
                      <span class="ml-1 text-xs text-slate-400">→</span>
                    </a>
                  </td>
                  <td
                    class="border-l border-slate-100 px-3 py-2 whitespace-nowrap text-slate-600"
                    title={fillTitle(r.slug)}
                  >
                    {fillCell(r.slug)}
                  </td>
                  <td class="px-3 py-2 text-slate-600">{modeLabel(r.slug)}</td>
                  <td class="px-3 py-2 text-right tabular-nums text-slate-600">
                    {r.homeSchools ?? "—"}
                  </td>
                  <td
                    class="px-3 py-2 text-right tabular-nums text-slate-600"
                    title={r.gaokao ? `${fmt(r.gaokao.count)} 人（${r.gaokao.year} 统考排名）` : undefined}
                  >
                    {r.gaokao ? wan(r.gaokao) : "—"}
                  </td>
                  <td
                    class="px-3 py-2 text-right tabular-nums text-slate-600"
                    title={r.benkeLine ? `${r.benkeLine.year} 物理类本科批控制线` : undefined}
                  >
                    {r.benkeLine ? r.benkeLine.line : "—"}
                  </td>
                  <td
                    class="px-3 py-2 text-right tabular-nums text-slate-600"
                    title={r.benkePlan ? `${fmt(r.benkePlan.plan)} 个本科招生计划（${r.benkePlan.year}）` : undefined}
                  >
                    {r.benkePlan ? wanNum(r.benkePlan.plan) : "—"}
                  </td>
                  <td class="border-l border-slate-100 px-3 py-2 text-right tabular-nums">
                    {fmt(r.coverage!.recruitSchools)}
                  </td>
                  <td class="px-3 py-2 text-right tabular-nums text-slate-600">{coverageYears(r.coverage)}</td>
                  <td class="px-3 py-2 text-right tabular-nums text-slate-600">{r.coverage!.count985}</td>
                  <td class="px-3 py-2 text-right tabular-nums text-slate-600">{r.coverage!.count211}</td>
                </tr>
              ) : (
                <tr class="border-t border-slate-100 text-slate-400">
                  <td class="px-3 py-2">
                    {r.name}
                    <span class="ml-2 rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-400">敬请期待</span>
                  </td>
                  <td class="border-l border-slate-100 px-3 py-2">—</td>
                  <td class="px-3 py-2" />
                  <td class="px-3 py-2 text-right tabular-nums text-slate-500">{r.homeSchools ?? "—"}</td>
                  <td class="px-3 py-2 text-right">—</td>
                  <td class="px-3 py-2 text-right">—</td>
                  <td class="px-3 py-2 text-right">—</td>
                  <td class="border-l border-slate-100 px-3 py-2 text-right">—</td>
                  <td class="px-3 py-2 text-right">—</td>
                  <td class="px-3 py-2 text-right">—</td>
                  <td class="px-3 py-2 text-right">—</td>
                </tr>
              ),
            )
          }
        </tbody>
      </table>
    </div>

    {/* 手机：每省一张卡片 */}
    <ul class="mt-6 space-y-2 md:hidden">
      {
        rows.map((r) =>
          r.live && r.slug ? (
            <li>
              <a
                href={`/${r.slug}/`}
                class="flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 transition hover:border-slate-400 hover:shadow-sm"
              >
                <div>
                  <div class="font-semibold text-slate-900">{r.name}</div>
                  <div class="mt-0.5 text-xs text-slate-500">
                    {modeLabel(r.slug)}
                    {r.gaokao && <> · 高考 {wan(r.gaokao)}</>}
                    {r.homeSchools != null && <> · 本省 {r.homeSchools} 校</>}
                    {r.benkeLine && <> · 本科线 {r.benkeLine.line}</>}
                    {r.benkePlan && <> · 本科计划 {wanNum(r.benkePlan.plan)}</>}
                  </div>
                  <div class="mt-0.5 text-xs text-slate-400">
                    收录 {fmt(r.coverage!.recruitSchools)} 所 · 数据到 {coverageYears(r.coverage)}
                  </div>
                  {fillOf(r.slug) && (
                    <div class="mt-1 inline-flex items-center rounded-md bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-800">
                      本科批填报 {fillCell(r.slug)}
                    </div>
                  )}
                </div>
                <span class="text-slate-400">→</span>
              </a>
            </li>
          ) : (
            <li class="flex items-center justify-between rounded-xl border border-dashed border-slate-200 bg-white/60 p-4">
              <span class="text-slate-400">
                {r.name}
                {r.homeSchools != null && (
                  <span class="ml-2 text-xs text-slate-400">本省 {r.homeSchools} 校</span>
                )}
              </span>
              <span class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-400">敬请期待</span>
            </li>
          ),
        )
      }
    </ul>

    <p class="mt-8 space-y-1 text-xs text-slate-400">
      <span class="block">
        <sup>*</sup>高考人数为<strong>参加统一高考排名的人数</strong>（各科类一分一段最大累计之和），
        不含高职单招/中职对口，非报名人数。
      </span>
      <span class="block">
        <sup>†</sup>本科线为<strong>物理类本科批最低控制线</strong>（源一分一段自带，如江苏 2025 物理 463），
        非更高的特殊类型招生控制线；浙江综合科、无物理科控制线的省显「—」。
      </span>
      <span class="block">
        <sup>‡</sup>本科招生计划为<strong>该省本科批招生计划总数</strong>（最新年，全国高校在该省的本科计划之和），
        配合高考人数可粗读本省本科竞争度。
      </span>
      <span class="block">
        <sup>§</sup>志愿填报为<strong>2026 年本科批普通类平行志愿集中填报起止</strong>（悬浮可见截止时刻与段次备注）；
        分段填报省（浙江、山东等）显第一段 / 常规批第 1 次，后续段次见备注。日期<strong>务必以本省教育考试院最新公告为准</strong>。
      </span>
      <span class="block">
        「本省院校 / 高考人数 / 本科线 / 本科招生计划 / 志愿填报」是省情事实；「招生院校 / 覆盖年份 / 名校数」是本站收录范围，
        受收录年份影响，非各省真实规模。仅供参考，以官方为准。
      </span>
    </p>
  </section>
</Base>
