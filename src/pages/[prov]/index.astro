---
import Base from "../../layouts/Base.astro";
import FenduanLookup from "../../components/FenduanLookup.tsx";
import Locator from "../../components/Locator.tsx";
import { PROVINCE_SLUGS, provinceConfig, fillRange } from "../../lib/provinces";
import { fenduanOf } from "../../lib/data";

export function getStaticPaths() {
  return PROVINCE_SLUGS.map((prov) => ({
    params: { prov },
    props: { prov, table: fenduanOf(prov) },
  }));
}

const { prov, table } = Astro.props;
const cfg = provinceConfig(prov);

// 填报单位措辞按省份：黑龙江=院校专业组；浙江=院校×专业。
const unit = cfg.fillModel === "group" ? "院校专业组" : "院校×专业";
// 老文理（新疆/西藏 wenli）无选科，措辞去掉「+ 选科」。
const selKePhrase = cfg.subjectMode === "wenli" ? "" : " + 选科";
// 只有分数省（西藏）：标题/文案改「分数定位」，隐藏分数↔位次单查（无一分一段）。
const scoreMode = cfg.locatorBasis === "score";
const locateName = scoreMode ? "分数定位" : "位次定位";
const inputPhrase = scoreMode ? "输入分数" : "输入分数或位次";
const basisPhrase = scoreMode ? "按分数差" : "按等效位次";
const seoInputPhrase = cfg.subjectMode === "wenli" ? inputPhrase : `${inputPhrase}并选择选科`;

const more = [
  { href: `/${prov}/yuanxiao/`, title: "院校浏览", desc: "历年录取线与位次走势" },
  { href: `/${prov}/zhuanye/`, title: "专业浏览", desc: "跨院校横向比录取水平" },
  { href: `/${prov}/guide/`, title: "报志愿指南", desc: "平行志愿 · 等效位次 · 选科" },
];

// 结构化数据：本页主体是该省的免费在线定位工具 → WebApplication（名称/描述随省份派生）。
// title / description 同时服务搜索摘要：保留省份、年份、定位方式、结果类型和数据口径，避免过短。
const pageTitle = `${cfg.name}${locateName}查询工具 · 2026高考志愿冲稳保推荐 · 高考志愿数据 Wiki`;
const pageDesc = `${cfg.name}2026高考志愿${locateName}工具，支持${seoInputPhrase}，${basisPhrase}匹配历年录取数据和招生计划，筛选院校层次、城市、专业大类与中外合作，生成冲、稳、保可填报${unit}，并提供分数位次换算、院校浏览、专业对比和报志愿方法指南，帮助考生和家长评估目标专业、保底选择与风险边界，合理安排志愿顺序，提供参考。`;
const appLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: `${cfg.name}${locateName}`,
  url: new URL(`/${prov}/`, Astro.site).href,
  applicationCategory: "EducationalApplication",
  operatingSystem: "Web",
  inLanguage: "zh-CN",
  isAccessibleForFree: true,
  description: pageDesc,
};
---

<Base
  prov={prov}
  title={pageTitle}
  description={pageDesc}
  jsonLd={appLd}
>
  <section class="mx-auto max-w-5xl px-4 py-8 sm:py-12">
    <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{locateName}</h1>
    <p class="mt-2 max-w-2xl text-sm text-slate-600 sm:text-base">
      {cfg.intro} —— {inputPhrase}{selKePhrase}，{basisPhrase}给出冲 / 稳 / 保的可填报{unit}。
      {scoreMode && "（西藏无位次/一分一段，按分数粗略定位，仅供参考。）"}
    </p>

    {/* 本科批志愿填报时间窗（2026 省情，时间敏感故置顶醒目）。缺数据则不显，不留空壳。 */}
    {
      cfg.fill && (
        <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3">
          <span class="inline-flex shrink-0 items-center rounded-md bg-amber-600 px-2 py-0.5 text-xs font-semibold text-white">
            本科批志愿填报
          </span>
          <span class="text-sm font-semibold text-amber-900">
            {fillRange(cfg.fill)}
            {cfg.fill.endTime && <span class="font-normal text-amber-700"> · {cfg.fill.endTime} 截止</span>}
          </span>
          {cfg.fill.note && <span class="text-xs text-amber-700">{cfg.fill.note}</span>}
          <span class="ml-auto text-xs text-amber-600">2026 · 以省考试院为准</span>
        </div>
      )
    }

    <div class="mt-6 sm:mt-8">
      <h2 class="mb-3 text-lg font-semibold tracking-tight text-slate-900">{cfg.name}{locateName}查询</h2>
      <Locator client:load prov={prov} table={table} />
    </div>

    {/* 次级入口：院校 / 专业 / 指南 */}
    <h2 class="mt-10 text-lg font-semibold tracking-tight text-slate-900">继续查询</h2>
    <div class="mt-3 grid gap-3 sm:grid-cols-3">
      {
        more.map((d) => (
          <a
            href={d.href}
            class="rounded-xl border border-slate-200 bg-white p-4 transition hover:border-slate-400 hover:shadow-sm"
          >
            <h3 class="text-sm font-semibold text-slate-900">{d.title}</h3>
            <div class="mt-0.5 text-xs text-slate-500">{d.desc}</div>
          </a>
        ))
      }
    </div>

    {/* 分数↔位次单查依赖一分一段——只有分数省（西藏）无此表，隐藏整块。 */}
    {
      !scoreMode && (
        <details class="mt-8">
          <summary class="cursor-pointer text-sm text-slate-500 hover:text-slate-800">只想单查 分数 ↔ 位次？</summary>
          <div class="mt-3">
            <FenduanLookup client:load table={table} />
          </div>
        </details>
      )
    }

    <p class="mt-8 text-xs text-slate-400">
      {
        scoreMode
          ? "分档：你的分高于录取线 ≥12 分 → 保；前后几分 → 稳；低 2–15 分 → 冲。分数随题目难易漂移，仅供参考，以官方为准。"
          : "分档阈值：你的位次 ≤ 录取线×0.9 → 保；≤ ×1.02 → 稳；≤ ×1.15 → 冲。仅供参考，以官方为准。"
      }
    </p>
  </section>
</Base>
