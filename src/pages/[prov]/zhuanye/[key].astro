---
import Base from "../../../layouts/Base.astro";
import { provinceConfig } from "../../../lib/provinces";
import type { MajorDetail } from "../../../lib/data";

export function getStaticPaths() {
  const files = import.meta.glob<{ default: MajorDetail }>("/src/data/*/majors/*.json", {
    eager: true,
  });
  return Object.entries(files).map(([path, m]) => {
    const prov = path.split("/")[3]; // /src/data/<prov>/majors/<key>.json
    return { params: { prov, key: m.default.key }, props: { prov, major: m.default } };
  });
}

const { prov, major } = Astro.props as { prov: string; major: MajorDetail };
const cfg = provinceConfig(prov);
---

<Base
  prov={prov}
  title={`${major.name} · 专业 · 高考志愿数据 Wiki`}
  description={`开设 ${major.name} 的各院校在${cfg.name}的录取最低位次横向比较。`}
>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <a href={`/${prov}/zhuanye/`} class="text-sm text-slate-500 hover:text-slate-800">← 专业浏览</a>
    <h1 class="mt-2 text-2xl font-bold">{major.name}</h1>
    <p class="mt-1 text-sm text-slate-500">
      {major.schools.length} 所院校开设（按最近最低位次排序）
    </p>

    <div class="mt-6 overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="border-b border-slate-300 text-left text-slate-500">
            <th class="py-2 pr-4">院校</th>
            <th class="py-2 pr-4">最近最低位次</th>
            <th class="py-2 pr-4">科类</th>
            <th class="py-2 pr-4">年份</th>
          </tr>
        </thead>
        <tbody>
          {
            major.schools.map((s) => (
              <tr class="border-b border-slate-100">
                <td class="py-2 pr-4">
                  <a
                    href={`/${prov}/yuanxiao/${s.sc}/#z-${s.mk}`}
                    class="font-medium text-slate-900 hover:underline"
                  >
                    {s.sn}
                  </a>
                </td>
                <td class="py-2 pr-4 tabular-nums">{s.minRank.toLocaleString()}</td>
                <td class="py-2 pr-4">{s.track}</td>
                <td class="py-2 pr-4 tabular-nums">{s.year}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="mt-10 text-xs text-slate-400">仅供参考，以官方及院校最新公布为准。</p>
  </section>
</Base>
