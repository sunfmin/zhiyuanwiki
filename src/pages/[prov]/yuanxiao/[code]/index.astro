---
import Base from "../../../../layouts/Base.astro";
import RankTrend from "../../../../components/RankTrend.astro";
import ScoreTrend from "../../../../components/ScoreTrend.astro";
import SchoolBadges from "../../../../components/SchoolBadges.tsx";
import { provinceConfig } from "../../../../lib/provinces";
import { schoolsOf } from "../../../../lib/data";
import type { SchoolDetail, Leaf } from "../../../../lib/data";

export function getStaticPaths() {
  const files = import.meta.glob<{ default: SchoolDetail }>("/src/data/*/schools/*.json", {
    eager: true,
  });
  return Object.entries(files).map(([path, m]) => {
    const prov = path.split("/")[3]; // /src/data/<prov>/schools/<code>.json
    return { params: { prov, code: m.default.code }, props: { prov, school: m.default } };
  });
}

const { prov, school } = Astro.props as { prov: string; school: SchoolDetail };
const cfg = provinceConfig(prov);
// 只有分数省（西藏）：无位次，全程改用最低分——排序/顶点/排行/走势都按分数（越高越难）。
const scoreMode = cfg.locatorBasis === "score";

const latest = (l: Leaf) => l.years.reduce((a, b) => (b.year >= a.year ? b : a), l.years[0]);
const leaves = school.leaves
  .slice()
  .sort((a, b) =>
    scoreMode ? latest(b).minScore - latest(a).minScore : latest(a).minRank - latest(b).minRank,
  );
const groups = school.groups2026 ?? [];
const plan = school.plan2026 ?? [];
const unit = cfg.fillModel === "group" ? "院校专业组" : "招生专业";
const unitCount = cfg.fillModel === "group" ? groups.length : plan.length;
const tracksLabel = cfg.tracks.map((t) => t.name).join(" / ");

// 院校身份头：层次徽标 + 录取区间，取自构建期索引（schools.json，仅含有录取记录的院校）。
// 位次是全站的决策数（站名即「位次」），故把位次区间做成首屏最醒目的读数。
const idx = schoolsOf(prov).find((s) => s.code === school.code);
const multiTrack = cfg.tracks.length > 1;
const trackName = cfg.tracks[0].name;

// 各科类区间 → 「最难考」顶点。位次省取 minRank 最小；只有分数省（西藏）取 maxScore 最高（录取分最高=最难）。
const trackRanges = idx ? cfg.tracks.map((t) => ({ track: t.name, r: idx.ranges?.[t.name] })).filter((x) => x.r) : [];
const hasRange = trackRanges.length > 0;
const apex = trackRanges.reduce<{ track: string; minRank: number; maxRank: number; minScore: number; maxScore: number; year: number } | null>(
  (best, x) =>
    !best || (scoreMode ? x.r!.maxScore > best.maxScore : x.r!.minRank < best.minRank)
      ? { track: x.track, ...x.r! }
      : best,
  null,
);
// 顶点专业：最新一年的代表读数 == 顶点的那个专业（位次省比 minRank；西藏比 minScore==顶点 maxScore）。
const apexMajor = apex
  ? leaves.find((l) => {
      const y = latest(l);
      const hit = scoreMode ? y.minScore === apex.maxScore : y.minRank === apex.minRank;
      return hit && (!multiTrack || y.track === apex.track);
    })
  : undefined;

// 招生专业「你在这里」排行：有往年位次的按最低位次从难到易排（planRanked），
// 无往年位次的（新增专业）单列在「新增 / 无往年录取」区（planNew）。存入位次后由 island 插分界线 + 标冲稳保。
const leafKeys = new Set(leaves.map((l) => l.majorKey));
// 有往年记录=能定位。位次省用 prevRank（升序，难→易）；只有分数省（西藏）用 prevScore（降序，分高=难→易）。
const hasPrev = (m: (typeof plan)[number]) =>
  scoreMode
    ? typeof m.prevScore === "number" && (m.prevScore as number) > 0
    : typeof m.prevRank === "number" && (m.prevRank as number) > 0;
const planRanked = plan
  .filter(hasPrev)
  .slice()
  .sort((a, b) =>
    scoreMode
      ? (b.prevScore as number) - (a.prevScore as number)
      : (a.prevRank as number) - (b.prevRank as number),
  );
const planNew = plan.filter((m) => !hasPrev(m));

const fmt = (n?: number) => (n != null && n > 0 ? n.toLocaleString("en-US") : "—");
const tierSeals = [
  idx?.is985 && { label: "985", kind: "985" },
  idx?.is211 && { label: "211", kind: "211" },
  idx?.isShuangYiLiu && { label: "双一流", kind: "syl" },
].filter(Boolean) as { label: string; kind: string }[];

// 页面主实体是该院校 → CollegeOrUniversity。工程标签（985/211/双一流）作 award。
const pageUrl = new URL(`/${prov}/yuanxiao/${school.code}/`, Astro.site).href;
// 标题/描述按当页数据填充：原「校名 · 院校 · 站名」太短（SEO 检测判 title 过短）、描述太空。
// 标题补省份 + 关键词 + 年份区间（典型落在 40–60 字符）；描述带层次徽标、顶点专业读数与收录规模，都源当页。
const tiers = tierSeals.map((t) => t.label).join("/");
const pageTitle = `${school.name}录取分数线与专业位次(2022–2025) · ${cfg.name} · 高考志愿数据 Wiki`;
const apexPhrase = apex
  ? `${scoreMode ? "录取分最高" : "最难考"}的专业${apexMajor ? apexMajor.majorName : ""}${scoreMode ? `录取最低分 ${apex.maxScore}` : `录取位次约 ${fmt(apex.minRank)}`}；`
  : "";
const coveragePhrase = [
  unitCount > 0 ? `${unitCount} 个 2026 ${unit}` : "",
  leaves.length > 0 ? `${leaves.length} 个有往年录取记录的专业` : "",
]
  .filter(Boolean)
  .join("、");
const pageDesc = `${school.name}${tiers ? `（${tiers}）` : ""}在${cfg.name}的 2026 招生与 2022–2025 历年专业录取数据。${apexPhrase}${coveragePhrase ? `覆盖 ${coveragePhrase}，` : ""}含各专业最低分与最低位次走势，按等效位次给出冲 / 稳 / 保填报参考。`;
const schoolLd = {
  "@context": "https://schema.org",
  "@type": "CollegeOrUniversity",
  name: school.name,
  url: pageUrl,
  description: pageDesc,
  ...(tierSeals.length ? { award: tierSeals.map((t) => t.label) } : {}),
};
---

<Base
  prov={prov}
  title={pageTitle}
  description={pageDesc}
  jsonLd={schoolLd}
>
  <div class="yx-page">
    <div class="yx-wrap">
      <a href={`/${prov}/yuanxiao/`} class="yx-back">← 院校浏览</a>

      {/* ───────── 院校身份头：先报最难考的位次（站名即「位次」） ───────── */}
      <header class="yx-masthead">
        <div class="yx-eyebrow">{cfg.name} · {tracksLabel} · 院校代码 {school.code}</div>
        <div class="yx-titlerow">
          <h1 class="yx-name">{school.name}</h1>
          {
            tierSeals.map((t) => (
              <span class={`yx-seal yx-seal--${t.kind}`}>{t.label}</span>
            ))
          }
        </div>
        <p class="yx-stats">
          院校代码 {school.code} · {unitCount} 个 2026 {unit} · {leaves.length} 个专业有 2022–2025 录取记录
        </p>

        {
          apex && (
            <div class="yx-apex">
              <div class="yx-apex-main">
                <h3 class="yx-apex-label">
                  {scoreMode ? "录取分最高的专业" : "最难考的专业"}
                  {multiTrack ? ` · ${apex.track}类` : ""} · {apex.year}
                </h3>
                <div class="yx-apex-num">
                  <span class="yx-apex-unit">{scoreMode ? "最低分" : "位次"}</span>
                  <span class="yx-apex-val">{scoreMode ? apex.maxScore : fmt(apex.minRank)}</span>
                </div>
                {apexMajor && <div class="yx-apex-major">{apexMajor.majorName}</div>}
                <div class="yx-apex-range">
                  {scoreMode
                    ? `录取最低分 ${apex.minScore}–${apex.maxScore}（含汉族/少数民族两类，源未区分）`
                    : `录取位次 ${fmt(apex.minRank)}–${fmt(apex.maxRank)} · 分 ${apex.minScore}–${apex.maxScore}`}
                </div>
              </div>
            </div>
          )
        }
      </header>

      {/* ───────── 黑龙江：院校专业组视图（保留，统一为墨纸样式） ───────── */}
      {
        cfg.fillModel === "group" && groups.length > 0 && (
          <section class="yx-section">
            <h2 class="yx-h2">2026 报考视图（院校专业组）</h2>
            <p class="yx-lede">
              平行志愿按院校专业组填报。组号逐年变，故往年位次按「院校 + 专业名」挂接到组内专业（非按组号）。
            </p>
            <div class="yx-groups">
              {groups.map((g) => (
                <div class="yx-card">
                  <div class="yx-group-head">
                    <h3 class="yx-group-name">{g.groupName}</h3>
                    <span class="yx-chip">{g.track}类</span>
                    {g.selKe && <span class="yx-chip yx-chip--sel">选科：{g.selKe}</span>}
                  </div>
                  <div class="yx-tablewrap">
                    <table class="yx-table">
                      <thead>
                        <tr>
                          <th>组内专业</th>
                          <th>选科</th>
                          <th>计划</th>
                          <th>学费</th>
                          <th>往年最低位次</th>
                        </tr>
                      </thead>
                      <tbody>
                        {g.majors.map((m) => (
                          <tr>
                            <td>
                              {leafKeys.has(m.majorKey) ? (
                                <a href={`#z-${m.majorKey}`} class="yx-majorlink">
                                  {m.majorName}
                                </a>
                              ) : (
                                <span class="yx-majorlink">{m.majorName}</span>
                              )}
                            </td>
                            <td class="yx-muted">{m.selKe || "—"}</td>
                            <td class="yx-num">{m.plan || "—"}</td>
                            <td class="yx-num">{m.tuition || "—"}</td>
                            <td class="yx-num">
                              {m.prevRank ? (
                                <>
                                  <span class="yx-rank">{m.prevRank.toLocaleString()}</span>
                                  <span class="yx-yr">{m.prevYear}</span>
                                </>
                              ) : (
                                "—"
                              )}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )
      }

      {/* ───────── 浙江：招生专业「你在这里」排行（按位次从难到易；存入位次后插分界线 + 冲稳保） ───────── */}
      {
        cfg.fillModel === "major" && plan.length > 0 && (
          <section class="yx-section">
            <h2 class="yx-h2">2026 报考视图（招生专业）</h2>
            <p class="yx-lede">
              专业平行志愿：每个院校×专业是独立投档单位（无组内调剂）。下面 {planRanked.length} 个有往年记录的专业按
              {scoreMode ? "最低分从高到低" : "最低位次从难到易"}排；
              在「{scoreMode ? "分数" : "位次"}定位」存入你的{scoreMode ? "分数" : "位次"}后，会在你所在档位画一条线，并标出每个专业是冲 / 稳 / 保。
              {scoreMode && "（录取分含汉族/少数民族两类线，源未区分。）"}
            </p>

            {planRanked.length > 0 && (
              <div class="yx-ranklist" data-track={trackName}>
                <div class="yx-rank-cap">↑ {scoreMode ? "录取分更高" : "更难考"}</div>
                {planRanked.map((m) => {
                  const linked = leafKeys.has(m.majorKey);
                  return (
                    <div
                      class="yx-rank-row"
                      data-rank={scoreMode ? undefined : m.prevRank}
                      data-score={scoreMode ? m.prevScore : undefined}
                    >
                      <div class="yx-rank-top">
                        <span class="yx-rank-name">
                          {linked ? <a href={`#z-${m.majorKey}`}>{m.majorName}</a> : m.majorName}
                          {m.coop && <span class="yx-coop">中外</span>}
                        </span>
                        <span
                          class="reach-tag"
                          data-rank={scoreMode ? undefined : m.prevRank}
                          data-score={scoreMode ? m.prevScore : undefined}
                          data-track={trackName}
                        />
                        <span class="yx-rank-r">
                          {scoreMode ? `${m.prevScore} 分` : `位次 ${(m.prevRank as number).toLocaleString()}`}
                          <span class="yx-rank-yr">{m.prevYear}</span>
                        </span>
                      </div>
                      <div class="yx-rank-sub">计划 {m.plan || "—"} · {m.selKe || "不限"}</div>
                    </div>
                  );
                })}
                <div class="yx-rank-cap">{scoreMode ? "录取分更低" : "更易考"} ↓</div>
                {/* 你的分界线：island 读 localStorage 后插到对应档位并显形 */}
                <div class="yx-youhere" hidden>
                  <span class="yx-youhere-v" />
                  <span class="yx-youhere-h">↑ 以上更难（冲 / 够不着）· 以下托底（保 / 过保）↓</span>
                </div>
              </div>
            )}

            {planNew.length > 0 && (
              <div class="yx-new">
                <h3 class="yx-new-cap">新增 / 无往年录取</h3>
                {planNew.map((m) => (
                  <span class="yx-new-item">
                    {leafKeys.has(m.majorKey) ? (
                      <a href={`#z-${m.majorKey}`} class="yx-majorlink">
                        {m.majorName}
                      </a>
                    ) : (
                      m.majorName
                    )}
                    <span class="yx-new-plan">计划 {m.plan || "—"} · {m.selKe || "不限"}</span>
                  </span>
                ))}
              </div>
            )}
          </section>
        )
      }

      {/* ───────── 全部专业 · 历年录取位次（可展开，墨纸账册） ───────── */}
      <section class="yx-section">
        <h2 class="yx-h2">{scoreMode ? "全部专业 · 历年录取分" : "全部专业 · 历年录取位次"}</h2>
        <p class="yx-lede">
          {scoreMode
            ? `点开专业看历年最低分走势（2022–2025 ${tracksLabel}类；录取分含汉族/少数民族两类线，源未区分）。`
            : `点开专业看历年最低分 / 最低位次走势（2022–2025 ${tracksLabel}类）。`}
        </p>
        {/* 每页恒有的 H3 分节标题（在 <details> 之外）：交代排序口径 + 专业数，兼顾 SEO 结构与可扫读 */}
        <h3 class="yx-subhead">
          {scoreMode ? "按录取分从高到低" : "按录取位次从难到易"} · 共 {leaves.length} 个专业
        </h3>
        <div class="yx-leaves">
          {
            leaves.map((l) => {
              const tracks = [...new Set(l.years.map((y) => y.track))];
              const y0 = latest(l);
              // 单科类省份（如浙江「综合」）每个专业只有一个科类，再标一行「综合类」是冗余；
              // 只有多科类（黑龙江 物理/历史 两套独立排名）才分头。
              const showTrackHeads = tracks.length > 1;
              return (
                <details id={`z-${l.majorKey}`} class="yx-leaf">
                  <summary class="yx-leaf-sum">
                    <span class="yx-leaf-name">{l.majorName}</span>
                    <span class="yx-leaf-tail">
                      {scoreMode ? (
                        <>最近最低分 <span class="yx-rank">{y0.minScore || "—"}</span></>
                      ) : (
                        <>最近最低位次 <span class="yx-rank">{y0.minRank.toLocaleString()}</span></>
                      )}
                      {multiTrack && ` · ${y0.track}类`}
                      {!scoreMode && ` · 选科 ${l.selKe || "—"}`}
                      {!showTrackHeads && (
                        <span
                          class="rank-badge"
                          data-rank={scoreMode ? undefined : y0.minRank}
                          data-score={scoreMode ? y0.minScore : undefined}
                          data-track={y0.track}
                        />
                      )}
                    </span>
                  </summary>
                  <div class="yx-leaf-body">
                    {tracks.map((tr) => {
                      const ys = l.years.filter((y) => y.track === tr).sort((a, b) => a.year - b.year);
                      const last = ys.length ? ys[ys.length - 1] : undefined;
                      const latestRank = last?.minRank ?? 0;
                      const latestScore = last?.minScore ?? 0;
                      return (
                        <div class="yx-leaf-track">
                          {showTrackHeads && (
                            <h4 class="yx-h3">
                              {tr}类
                              <span
                                class="rank-badge"
                                data-rank={scoreMode ? undefined : latestRank}
                                data-score={scoreMode ? latestScore : undefined}
                                data-track={tr}
                              />
                            </h4>
                          )}
                          <div class="yx-tablewrap">
                            <table class="yx-table">
                              <thead>
                                {scoreMode ? (
                                  <tr>
                                    <th>年份</th>
                                    <th>录取最低分</th>
                                    <th>录取最高分</th>
                                  </tr>
                                ) : (
                                  <tr>
                                    <th>年份</th>
                                    <th>最低分</th>
                                    <th>最低位次</th>
                                    <th>最高分</th>
                                  </tr>
                                )}
                              </thead>
                              <tbody>
                                {ys.map((y) =>
                                  scoreMode ? (
                                    <tr class="yx-num">
                                      <td>{y.year}</td>
                                      <td><span class="yx-rank">{y.minScore || "—"}</span></td>
                                      <td>{y.maxScore && y.maxScore > y.minScore ? y.maxScore : "—"}</td>
                                    </tr>
                                  ) : (
                                    <tr class="yx-num">
                                      <td>{y.year}</td>
                                      <td>{y.minScore || "—"}</td>
                                      <td><span class="yx-rank">{y.minRank.toLocaleString()}</span></td>
                                      <td>{y.maxScore || "—"}</td>
                                    </tr>
                                  ),
                                )}
                              </tbody>
                            </table>
                          </div>
                          <div class="yx-spark">
                            {scoreMode ? (
                              <ScoreTrend points={ys.map((y) => ({ year: y.year, minScore: y.minScore }))} />
                            ) : (
                              <RankTrend points={ys.map((y) => ({ year: y.year, minRank: y.minRank }))} />
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </details>
              );
            })
          }
        </div>
      </section>

      <SchoolBadges client:load prov={prov} />

      <p class="yx-fineprint">仅供参考，以官方及院校最新公布为准。</p>
    </div>
  </div>
</Base>

<style>
  /* 把全站的决策数「位次」做成首屏与签名件；朱砂红只给位次用。
     配色 / 字体与站点其他页面一致：slate 中性色 + 系统无衬线（--font-display 仅继承 body 字体，
     留作日后想换展示字体的钩子）。 */
  .yx-page {
    --paper: #f8fafc; /* slate-50，同其他页面背景 */
    --card: #ffffff;
    --ink: #0f172a; /* slate-900 */
    --ink-soft: #64748b; /* slate-500 */
    --ink-faint: #94a3b8; /* slate-400 */
    --seal: #c0202e; /* 朱红：位次高亮 */
    --seal-deep: #9f1239;
    --gold: #b45309; /* amber-700，同其他页面 双一流 徽标 */
    --rule: #e2e8f0; /* slate-200 */
    --rule-strong: #cbd5e1; /* slate-300 */
    --font-display: inherit; /* = body 的系统无衬线（站点统一字体） */
    background: var(--paper);
    color: var(--ink);
    min-height: 100%;
    padding-bottom: 4rem;
  }
  .yx-wrap {
    max-width: 56rem;
    margin: 0 auto;
    padding: 1.25rem 1.25rem 0;
  }
  .yx-back {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    color: var(--ink-faint);
    text-decoration: none;
    transition: color 0.15s;
  }
  .yx-back:hover { color: var(--seal); }

  /* ── 院校身份头 ── */
  .yx-masthead { padding: 1rem 0 0; }
  .yx-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: none;
    color: var(--ink-faint);
    font-weight: 600;
  }
  .yx-titlerow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.65rem;
    margin-top: 0.5rem;
  }
  .yx-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 3rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em; /* tracking-tight，同其他页面 h1 */
    margin: 0;
  }
  .yx-seal {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.22rem 0.46rem;
    border: 1px solid currentColor;
    border-radius: 3px;
    line-height: 1;
    align-self: center;
  }
  .yx-seal--985 { color: var(--seal); background: rgba(192, 32, 46, 0.06); }
  .yx-seal--211 { color: var(--ink); background: rgba(33, 30, 26, 0.04); }
  .yx-seal--syl { color: var(--gold); background: rgba(154, 123, 46, 0.08); }
  .yx-stats {
    margin: 0.7rem 0 0;
    font-size: 0.8125rem;
    color: var(--ink-soft);
  }

  /* ── 顶点位次读数（首屏主角） ── */
  .yx-apex {
    margin-top: 1.5rem;
    padding-top: 1.4rem;
    border-top: 2px solid var(--ink);
  }
  .yx-apex-label {
