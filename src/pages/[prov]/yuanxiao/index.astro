---
import Base from "../../../layouts/Base.astro";
import SchoolSearch from "../../../components/SchoolSearch.tsx";
import { PROVINCE_SLUGS, provinceConfig } from "../../../lib/provinces";
import { schoolsOf } from "../../../lib/data";

export function getStaticPaths() {
  return PROVINCE_SLUGS.map((prov) => ({
    params: { prov },
    props: { prov, list: schoolsOf(prov) },
  }));
}

const { prov, list } = Astro.props;
const cfg = provinceConfig(prov);
const tracksLabel = cfg.tracks.map((t) => t.name).join(" / ");
const multiTrack = cfg.tracks.length > 1;
---

<Base
  prov={prov}
  title={`院校浏览 · ${cfg.name} · 高考志愿数据 Wiki`}
  description={`搜索并浏览${cfg.name}各院校的历年专业录取分数线、位次走势与 2026 招生计划。`}
>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="text-2xl font-bold">院校浏览</h1>
    <p class="mt-2 text-slate-600">
      {cfg.name} 2022–2025 {tracksLabel}类有录取记录的院校，共 {list.length} 所。搜院校名进去看历年走势与 2026 报考视图。
    </p>

    <p class="mt-2 text-xs text-slate-400">
      区间取该校最新年份各专业录取线的范围：分 = 最低分–最高分，位次 = 最好位次–最差位次（数值越小越靠前）。
      {multiTrack && "物理 / 历史是两套独立的全省排名，分开列、不可跨类比位次。"}
    </p>

    <div class="mt-8">
      <SchoolSearch client:load schools={list} prov={prov} />
    </div>
  </section>
</Base>
