---
import Base from "../../layouts/Base.astro";
import FenduanLookup from "../../components/FenduanLookup.tsx";
import type { YiFenYiDuan } from "../../lib/fenduan";
import wuli2026 from "../../data/yifenyiduan/wuli-2026.json";

const table = wuli2026 as YiFenYiDuan;
---

<Base title="位次定位 · 高考志愿数据 Wiki" description="黑龙江物理类分数与位次互换，基于官方一分一段表。">
  <section class="mx-auto max-w-2xl px-4 py-14">
    <h1 class="text-2xl font-bold">位次定位</h1>
    <p class="mt-2 text-slate-600">
      黑龙江 · 2026 · 物理类 —— 分数 ↔ 位次互换，基于官方一分一段表。
    </p>

    <div class="mt-8">
      <FenduanLookup client:load table={table} />
    </div>

    <p class="mt-6 text-sm text-slate-500">
      位次比分数更稳：题目难易每年浮动，但"排第几名能上哪所学校"相对恒定。
      完整的"输入位次 → 冲 / 稳 / 保院校专业列表"定位功能见 issue #6。
    </p>
  </section>
</Base>
