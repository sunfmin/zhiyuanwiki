---
import Base from "../../layouts/Base.astro";
import SchoolSearch from "../../components/SchoolSearch.tsx";
import schools from "../../data/schools.json";

type Entry = { code: string; name: string; leafCount: number };
const list = (schools as Entry[]).slice().sort((a, b) => b.leafCount - a.leafCount);
---

<Base title="院校浏览 · 高考志愿数据 Wiki" description="搜索并浏览院校的历年专业录取分数线、位次走势与 2026 招生专业组。">
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="text-2xl font-bold">院校浏览</h1>
    <p class="mt-2 text-slate-600">
      黑龙江 2023–2025 物理 / 历史类本科批有录取记录的院校。搜院校名进去看历年走势与 2026 报考视图。
    </p>

    <div class="mt-8">
      <SchoolSearch client:load schools={list} />
    </div>
  </section>
</Base>
