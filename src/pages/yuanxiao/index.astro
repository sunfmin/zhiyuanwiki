---
import Base from "../../layouts/Base.astro";
import schools from "../../data/schools.json";

type Entry = { code: string; name: string; leafCount: number };
const list = (schools as Entry[])
  .slice()
  .sort((a, b) => b.leafCount - a.leafCount);
const total = list.length;
---

<Base title="院校浏览 · 高考志愿数据 Wiki" description="按院校浏览黑龙江历年专业录取分数线与位次走势。">
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="text-2xl font-bold">院校浏览</h1>
    <p class="mt-2 text-slate-600">
      共 {total} 所院校（黑龙江 2023–2025 物理 / 历史类本科批有录取记录）。点进任一院校看其历年录取走势与开设专业。
    </p>

    <ul class="mt-8 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
      {
        list.map((s) => (
          <li>
            <a
              href={`/yuanxiao/${s.code}/`}
              class="flex items-baseline justify-between rounded-lg border border-slate-200 bg-white px-3 py-2 hover:border-slate-400"
            >
              <span class="font-medium">{s.name}</span>
              <span class="ml-2 shrink-0 text-xs text-slate-400">
                {s.code} · {s.leafCount} 专业
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
