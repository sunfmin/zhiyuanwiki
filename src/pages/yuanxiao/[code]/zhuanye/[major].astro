---
import Base from "../../../../layouts/Base.astro";
import RankTrend from "../../../../components/RankTrend.astro";

type Year = { year: number; track: string; minScore: number; minRank: number; maxScore: number };
type Leaf = { majorKey: string; majorName: string; selKe: string; years: Year[] };
type Detail = { code: string; name: string; leaves: Leaf[] };

export function getStaticPaths() {
  const files = import.meta.glob<{ default: Detail }>("/src/data/schools/*.json", {
    eager: true,
  });
  const paths = [];
  for (const m of Object.values(files)) {
    const s = m.default;
    for (const leaf of s.leaves) {
      paths.push({
        params: { code: s.code, major: leaf.majorKey },
        props: { schoolName: s.name, schoolCode: s.code, leaf },
      });
    }
  }
  return paths;
}

const { schoolName, schoolCode, leaf } = Astro.props as {
  schoolName: string;
  schoolCode: string;
  leaf: Leaf;
};

const tracks = [...new Set(leaf.years.map((y) => y.track))];
---

<Base
  title={`${leaf.majorName} · ${schoolName} · 高考志愿数据 Wiki`}
  description={`${schoolName} ${leaf.majorName} 在黑龙江的历年录取最低分 / 最低位次走势。`}
>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <nav class="text-sm text-slate-500">
      <a href="/yuanxiao/" class="hover:text-slate-800">院校浏览</a>
      <span class="px-1">/</span>
      <a href={`/yuanxiao/${schoolCode}/`} class="hover:text-slate-800">{schoolName}</a>
    </nav>

    <h1 class="mt-2 text-2xl font-bold">{leaf.majorName}</h1>
    <p class="mt-1 text-sm text-slate-500">
      {schoolName}（{schoolCode}） · 选科要求：{leaf.selKe || "—"}
    </p>

    {
      tracks.map((tr) => {
        const ys = leaf.years.filter((y) => y.track === tr).sort((a, b) => a.year - b.year);
        return (
          <div class="mt-8">
            <h2 class="text-lg font-semibold">{tr}类</h2>
            <div class="mt-3 overflow-x-auto">
              <table class="w-full border-collapse text-sm">
                <thead>
                  <tr class="border-b border-slate-300 text-left text-slate-500">
                    <th class="py-2 pr-4">年份</th>
                    <th class="py-2 pr-4">最低分</th>
                    <th class="py-2 pr-4">最低位次</th>
                    <th class="py-2 pr-4">最高分</th>
                  </tr>
                </thead>
                <tbody>
                  {ys.map((y) => (
                    <tr class="border-b border-slate-100 tabular-nums">
                      <td class="py-2 pr-4">{y.year}</td>
                      <td class="py-2 pr-4">{y.minScore || "—"}</td>
                      <td class="py-2 pr-4">{y.minRank.toLocaleString()}</td>
                      <td class="py-2 pr-4">{y.maxScore || "—"}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="mt-3">
              <RankTrend points={ys.map((y) => ({ year: y.year, minRank: y.minRank }))} />
            </div>
          </div>
        );
      })
    }

    <p class="mt-10 text-xs text-slate-400">
      数据来源：万师兄·高考志愿填报大数据（第三方整理）。最低位次按等效位次法用于跨年比较；仅供参考，以官方及院校最新公布为准。
    </p>
  </section>
</Base>
