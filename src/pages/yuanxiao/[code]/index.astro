---
import Base from "../../../layouts/Base.astro";
import RankTrend from "../../../components/RankTrend.astro";
import SchoolBadges from "../../../components/SchoolBadges.tsx";

type Year = { year: number; track: string; minScore: number; minRank: number; maxScore: number };
type Leaf = { majorKey: string; majorName: string; selKe: string; years: Year[] };
type GroupMajor = {
  majorName: string;
  majorKey: string;
  selKe: string;
  plan: number;
  tuition: string;
  prevYear?: number;
  prevRank?: number;
  equivRank?: number;
};
type Group = { groupCode: string; groupName: string; track: string; selKe: string; majors: GroupMajor[] };
type Detail = { code: string; name: string; leaves: Leaf[]; groups2026: Group[] };

export function getStaticPaths() {
  const files = import.meta.glob<{ default: Detail }>("/src/data/schools/*.json", {
    eager: true,
  });
  return Object.values(files).map((m) => ({
    params: { code: m.default.code },
    props: { school: m.default },
  }));
}

const { school } = Astro.props as { school: Detail };

const latest = (l: Leaf) => l.years.reduce((a, b) => (b.year >= a.year ? b : a), l.years[0]);
const leaves = school.leaves.slice().sort((a, b) => latest(a).minRank - latest(b).minRank);
const groups = school.groups2026 ?? [];
---

<Base
  title={`${school.name} · 院校 · 高考志愿数据 Wiki`}
  description={`${school.name}在黑龙江的 2026 招生专业组与历年专业录取位次（2023–2025）。`}
>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <a href="/yuanxiao/" class="text-sm text-slate-500 hover:text-slate-800">← 院校浏览</a>
    <h1 class="mt-2 text-2xl font-bold">{school.name}</h1>
    <p class="mt-1 text-sm text-slate-500">
      院校代码 {school.code} · {groups.length} 个 2026 院校专业组 · {leaves.length} 个专业有 2023–2025 录取记录
    </p>

    {
      groups.length > 0 && (
        <div class="mt-8">
          <h2 class="text-lg font-semibold">2026 报考视图（院校专业组）</h2>
          <p class="mt-1 text-xs text-slate-500">
            平行志愿按院校专业组填报。组号逐年变，故往年位次按"院校 + 专业名"挂接到组内专业（非按组号）。
          </p>
          <div class="mt-4 space-y-6">
            {groups.map((g) => (
              <div class="rounded-xl border border-slate-200 bg-white p-4">
                <div class="flex flex-wrap items-baseline gap-2">
                  <span class="font-semibold">{g.groupName}</span>
                  <span class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-600">{g.track}类</span>
                  {g.selKe && (
                    <span class="rounded bg-amber-50 px-1.5 py-0.5 text-xs text-amber-700">选科：{g.selKe}</span>
                  )}
                </div>
                <div class="mt-3 overflow-x-auto">
                  <table class="w-full border-collapse text-sm">
                    <thead>
                      <tr class="border-b border-slate-300 text-left text-slate-500">
                        <th class="py-1.5 pr-4">组内专业</th>
                        <th class="py-1.5 pr-4">选科</th>
                        <th class="py-1.5 pr-4">计划</th>
                        <th class="py-1.5 pr-4">学费</th>
                        <th class="py-1.5 pr-4">往年最低位次</th>
                      </tr>
                    </thead>
                    <tbody>
                      {g.majors.map((m) => (
                        <tr class="border-b border-slate-100">
                          <td class="py-1.5 pr-4">
                            <a href={`#z-${m.majorKey}`} class="text-slate-900 hover:underline">
                              {m.majorName}
                            </a>
                          </td>
                          <td class="py-1.5 pr-4 text-slate-600">{m.selKe || "—"}</td>
                          <td class="py-1.5 pr-4 tabular-nums">{m.plan || "—"}</td>
                          <td class="py-1.5 pr-4 tabular-nums">{m.tuition || "—"}</td>
                          <td class="py-1.5 pr-4 tabular-nums">
                            {m.prevRank ? `${m.prevRank.toLocaleString()}（${m.prevYear}）` : "—"}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-12">
      <h2 class="text-lg font-semibold">全部专业 · 历年录取位次</h2>
      <p class="mt-1 text-xs text-slate-500">点开专业看历年最低分 / 最低位次走势（2023–2025 物理 / 历史类）。</p>
      <div class="mt-4">
        {
          leaves.map((l) => {
            const tracks = [...new Set(l.years.map((y) => y.track))];
            const y0 = latest(l);
            return (
              <details id={`z-${l.majorKey}`} class="border-b border-slate-100">
                <summary class="flex cursor-pointer flex-wrap items-baseline justify-between gap-x-3 py-2">
                  <span class="font-medium text-slate-900">{l.majorName}</span>
                  <span class="text-sm text-slate-500">
                    最近最低位次 {y0.minRank.toLocaleString()} · {y0.track}类 · 选科 {l.selKe || "—"}
                  </span>
                </summary>
                <div class="pb-5 pl-1">
                  {tracks.map((tr) => {
                    const ys = l.years.filter((y) => y.track === tr).sort((a, b) => a.year - b.year);
                    const latestRank = ys.length ? ys[ys.length - 1].minRank : 0;
                    return (
                      <div class="mt-3">
                        <h3 class="text-sm font-semibold">
                          {tr}类
                          <span class="rank-badge" data-rank={latestRank} data-track={tr} />
                        </h3>
                        <div class="mt-2 overflow-x-auto">
                          <table class="w-full border-collapse text-sm">
                            <thead>
                              <tr class="border-b border-slate-300 text-left text-slate-500">
                                <th class="py-1 pr-4">年份</th>
                                <th class="py-1 pr-4">最低分</th>
                                <th class="py-1 pr-4">最低位次</th>
                                <th class="py-1 pr-4">最高分</th>
                              </tr>
                            </thead>
                            <tbody>
                              {ys.map((y) => (
                                <tr class="border-b border-slate-100 tabular-nums">
                                  <td class="py-1 pr-4">{y.year}</td>
                                  <td class="py-1 pr-4">{y.minScore || "—"}</td>
                                  <td class="py-1 pr-4">{y.minRank.toLocaleString()}</td>
                                  <td class="py-1 pr-4">{y.maxScore || "—"}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                        <div class="mt-2">
                          <RankTrend points={ys.map((y) => ({ year: y.year, minRank: y.minRank }))} />
                        </div>
                      </div>
                    );
                  })}
                </div>
              </details>
            );
          })
        }
      </div>
    </div>

    <SchoolBadges client:load />

    <p class="mt-10 text-xs text-slate-400">
      数据来源：万师兄·高考志愿填报大数据（第三方整理）。仅供参考，以官方及院校最新公布为准。
    </p>
  </section>
</Base>
