---
import "../styles/global.css";
import { provinceConfig } from "../lib/provinces";

interface Props {
  prov?: string; // 省份页传入；落地页（省份列表页 /）不传，渲染极简头部
  title?: string;
  description?: string;
}

const {
  prov,
  title = "高考志愿数据 Wiki",
  description = "用历年官方数据帮助高考考生选择院校与专业。",
} = Astro.props;

const cfg = prov ? provinceConfig(prov) : null;

// 顶部导航：位次定位是省份主页（/<prov>/）。当前所在区块高亮。
// 路径形如 /<prov>/[section]/...；section 为空即定位主页。落地页无 prov → 无省份导航。
const path = Astro.url.pathname;
const seg = path.split("/").filter(Boolean); // ["hlj","yuanxiao",...]
const section = prov ? (seg[1] ?? "") : "";
const navLinks = prov
  ? [
      { section: "", href: `/${prov}/`, label: "位次定位" },
      { section: "yuanxiao", href: `/${prov}/yuanxiao/`, label: "院校" },
      { section: "zhuanye", href: `/${prov}/zhuanye/`, label: "专业" },
      { section: "guide", href: `/${prov}/guide/`, label: "指南" },
    ]
  : [];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-5xl items-center gap-3 px-4 py-2.5 sm:gap-5">
        <a href={prov ? `/${prov}/` : "/"} class="flex shrink-0 items-center gap-2" aria-label="高考志愿数据 Wiki 首页">
          <span class="grid h-7 w-7 place-items-center rounded-lg bg-slate-900 text-sm font-bold text-white">
            位
          </span>
          <span class="text-sm font-semibold tracking-tight text-slate-900">
            高考志愿数据
          </span>
        </a>
        {
          prov && cfg && (
            <>
              <div class="flex items-center gap-1 overflow-x-auto text-sm">
                {navLinks.map((l) => (
                  <a
                    href={l.href}
                    aria-current={l.section === section ? "page" : undefined}
                    class={`shrink-0 rounded-md px-2 py-1 transition ${
                      l.section === section
                        ? "bg-slate-100 font-medium text-slate-900"
                        : "text-slate-500 hover:text-slate-900"
                    }`}
                  >
                    {l.label}
                  </a>
                ))}
              </div>
              {/* 省份：链接到省份列表页（/）切换，替代原下拉选择（见 ADR-0016 落地页）。 */}
              <a
                href="/"
                class="ml-auto flex shrink-0 items-center gap-1 rounded-md border border-slate-300 bg-white px-2 py-1 text-sm text-slate-900 transition hover:border-slate-400 hover:text-blue-700"
              >
                <span class="hidden text-xs text-slate-500 sm:inline">省份</span>
                <span class="font-medium">{cfg.name}</span>
                <span class="text-xs text-slate-400">切换</span>
              </a>
            </>
          )
        }
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-6 text-xs text-slate-500 space-y-1">
        <p>本站数据<strong>仅供参考</strong>，一切以各省考试院及院校最新官方公布为准。</p>
      </div>
    </footer>
  </body>
</html>
