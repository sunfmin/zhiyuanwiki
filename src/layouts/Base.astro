---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "高考志愿数据 Wiki",
  description = "用历年官方数据帮助高考考生选择院校与专业（黑龙江物理 / 历史类先行）",
} = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto max-w-5xl px-4 py-3 flex items-center gap-6 text-sm">
        <a href="/" class="font-semibold">高考志愿数据 Wiki</a>
        <a href="/dingwei" class="text-slate-600 hover:text-slate-900">位次定位</a>
        <a href="/yuanxiao" class="text-slate-600 hover:text-slate-900">院校</a>
        <a href="/zhuanye" class="text-slate-600 hover:text-slate-900">专业</a>
        <a href="/guide" class="text-slate-600 hover:text-slate-900">指南</a>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-6 text-xs text-slate-500 space-y-1">
        <p>
          数据来源：黑龙江省招生考试信息港（lzk.hl.cn）官方公开数据，及万师兄·高考志愿填报大数据（第三方整理）。
        </p>
        <p>本站数据<strong>仅供参考</strong>，一切以各省考试院及院校最新官方公布为准。</p>
      </div>
    </footer>
  </body>
</html>
