---
import "../styles/global.css";
import { provinceConfig } from "../lib/provinces";

interface Props {
  prov?: string; // 省份页传入；落地页（省份列表页 /）不传，渲染极简头部
  title?: string;
  description?: string;
  canonical?: string; // 覆盖 canonical（绝对 URL 或站内路径）；缺省 = 当前页自指
  ogType?: string; // Open Graph 类型，缺省 website；文章页传 article
  noindex?: boolean; // 置 true 输出 noindex（如需屏蔽某页收录）
  jsonLd?: object | object[]; // 页面级结构化数据（院校 / 文章等），与站点级 WebSite 合并输出
}

const SITE_NAME = "高考志愿数据 Wiki";

const {
  prov,
  title = SITE_NAME,
  description = "用历年官方数据帮助高考考生选择院校与专业。",
  canonical,
  ogType = "website",
  noindex = false,
  jsonLd,
} = Astro.props;

const cfg = prov ? provinceConfig(prov) : null;

// 路径形如 /<prov>/[section]/...；section 为空即定位主页。落地页无 prov → 无省份导航。
const path = Astro.url.pathname;
const seg = path.split("/").filter(Boolean); // ["hlj","yuanxiao",...]
const section = prov ? (seg[1] ?? "") : "";

// ── 规范化 URL / 社交卡片 ──────────────────────────────────────────────
// 生产站为 R2 + trailingSlash:'always'，canonical 一律带尾斜杠的绝对 URL，收敛重复路径
//（…/index.html、无尾斜杠目录都 308 回 …/）。canonical 传站内路径时按同规则补全为绝对 URL。
const SITE = Astro.site ?? new URL("https://zhiyuanwiki.com");
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, SITE).href;
const ogImage = new URL("/og.png", SITE).href;

// ── 结构化数据 ────────────────────────────────────────────────────────
// 站点级 WebSite 每页都发（体量极小、信号一致）；页面级节点由各模板经 jsonLd 传入。
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: SITE.href,
  inLanguage: "zh-CN",
  description: "用历年官方数据帮助高考考生按等效位次选择院校与专业。",
};
const pageLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// ── 面包屑（结构化）────────────────────────────────────────────────────
// 从路径自动生成：首页 › 省 › 板块 › 叶子。叶子名取 title 的首段（"浙江大学 · 院校 · …"→"浙江大学"）。
const SECTION_LABEL: Record<string, string> = { yuanxiao: "院校", zhuanye: "专业", guide: "指南" };
const crumbs: { name: string; url: string }[] = [{ name: "首页", url: SITE.href }];
if (prov && cfg) {
  crumbs.push({ name: cfg.name, url: new URL(`/${prov}/`, SITE).href });
  if (section && SECTION_LABEL[section]) {
    crumbs.push({ name: SECTION_LABEL[section], url: new URL(`/${prov}/${section}/`, SITE).href });
    // 叶子页（省/板块/条目，3 段）再加一层：条目名取自页面标题首段。
    if (seg.length >= 3) {
      crumbs.push({ name: title.split(" · ")[0], url: canonicalUrl });
    }
  }
}
const breadcrumbLd =
  crumbs.length > 1
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: crumbs.map((c, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: c.name,
          item: c.url,
        })),
      }
    : null;
const allLd = [websiteLd, ...(breadcrumbLd ? [breadcrumbLd] : []), ...pageLd];

// 顶部导航：位次定位是省份主页（/<prov>/）。当前所在区块高亮。
const navLinks = prov
  ? [
      // 只有分数省（西藏）无位次，主页是「分数定位」。
      { section: "", href: `/${prov}/`, label: cfg?.locatorBasis === "score" ? "分数定位" : "位次定位" },
      { section: "yuanxiao", href: `/${prov}/yuanxiao/`, label: "院校" },
      { section: "zhuanye", href: `/${prov}/zhuanye/`, label: "专业" },
      { section: "guide", href: `/${prov}/guide/`, label: "指南" },
    ]
  : [];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* Open Graph（微信 / 微博 / X 分享卡片） */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* 结构化数据：站点级 WebSite + 面包屑 + 页面级节点 */}
    {allLd.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-5xl items-center gap-3 px-4 py-2.5 sm:gap-5">
        <a href={prov ? `/${prov}/` : "/"} class="flex shrink-0 items-center gap-2" aria-label="高考志愿数据 Wiki 首页">
          <span class="grid h-7 w-7 place-items-center rounded-lg bg-slate-900 text-sm font-bold text-white">
            位
          </span>
          <span class="text-sm font-semibold tracking-tight text-slate-900">
            高考志愿数据
          </span>
        </a>
        {
          prov && cfg && (
            <>
              <div class="flex items-center gap-1 overflow-x-auto text-sm">
                {navLinks.map((l) => (
                  <a
                    href={l.href}
                    aria-current={l.section === section ? "page" : undefined}
                    class={`shrink-0 rounded-md px-2 py-1 transition ${
                      l.section === section
                        ? "bg-slate-100 font-medium text-slate-900"
                        : "text-slate-500 hover:text-slate-900"
                    }`}
                  >
                    {l.label}
                  </a>
                ))}
              </div>
              {/* 省份：链接到省份列表页（/）切换，替代原下拉选择（见 ADR-0016 落地页）。 */}
              <a
                href="/"
                class="ml-auto flex shrink-0 items-center gap-1 rounded-md border border-slate-300 bg-white px-2 py-1 text-sm text-slate-900 transition hover:border-slate-400 hover:text-blue-700"
              >
                <span class="hidden text-xs text-slate-500 sm:inline">省份</span>
                <span class="font-medium">{cfg.name}</span>
                <span class="text-xs text-slate-400">切换</span>
              </a>
            </>
          )
        }
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-6 text-xs text-slate-500 space-y-1">
        <p>本站数据<strong>仅供参考</strong>，一切以各省考试院及院校最新官方公布为准。</p>
      </div>
    </footer>
  </body>
</html>
