---
// 单科类的最低分走势 sparkline（只有分数省=西藏）。分数越高越好 → 画在越靠上（与 RankTrend 的「位次越小越上」对称）。
interface Pt {
  year: number;
  minScore: number;
}
interface Props {
  points: Pt[];
}
const { points } = Astro.props;
const pts = points.filter((p) => p.minScore > 0).sort((a, b) => a.year - b.year);

const w = 260;
const h = 64;
const pad = 8;
let poly = "";
let dots: { x: number; y: number; year: number; score: number }[] = [];
if (pts.length >= 1) {
  const scores = pts.map((p) => p.minScore);
  const min = Math.min(...scores);
  const max = Math.max(...scores);
  const span = max - min || 1;
  const n = pts.length;
  dots = pts.map((p, i) => {
    const x = n === 1 ? w / 2 : pad + (i * (w - 2 * pad)) / (n - 1);
    const y = pad + ((max - p.minScore) / span) * (h - 2 * pad); // max(最高分=最难) → 顶部
    return { x, y, year: p.year, score: p.minScore };
  });
  poly = dots.map((d) => `${d.x},${d.y}`).join(" ");
}
---

{
  pts.length >= 2 && (
    <svg viewBox={`0 0 ${w} ${h}`} class="w-full max-w-[260px]">
      <polyline points={poly} fill="none" stroke="#94a3b8" stroke-width="1.5" />
      {dots.map((d, i) => (
        <circle cx={d.x} cy={d.y} r={i === dots.length - 1 ? 3 : 2.5} fill={i === dots.length - 1 ? "#c0202e" : "#94a3b8"}>
          <title>{`${d.year}：最低分 ${d.score}`}</title>
        </circle>
      ))}
    </svg>
  )
}
